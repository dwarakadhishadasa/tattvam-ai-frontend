# GEMINI_API_KEY: Required for server-side Gemini AI calls.
# Configure this in .env.local for local development and in Vercel Development,
# Preview, and Production for deployed environments.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TATTVAM_NOTEBOOK_BACKEND_ORIGIN: Server-side notebook backend origin used for notebook creation,
# source-text seeding, and extraction chat transport. 0.0.0.0 is normalized to 127.0.0.1 at runtime.
# In Vercel, set this explicitly to https://tattvam-ai-backend-two.vercel.app unless a different
# environment-specific backend is intentionally provisioned. Preview should prefer non-production
# notebook resources unless explicitly accepted.
TATTVAM_NOTEBOOK_BACKEND_ORIGIN="http://127.0.0.1:8000"

# TATTVAM_EXTRACTION_CHAT_NOTEBOOK_ID: Legacy single-target notebook id for POST /api/chat.
TATTVAM_EXTRACTION_CHAT_NOTEBOOK_ID="da406743-a373-47f9-9275-6c2e1e86c2b6"

# TATTVAM_EXTRACTION_CHAT_TARGETS_JSON: Fixed four-target registry for POST /api/chat/stream.
# Keep Development, Preview, and Production aligned to the same JSON shape, while
# allowing Preview to point at preview-safe notebook ids.
TATTVAM_EXTRACTION_CHAT_TARGETS_JSON='[
  {"key":"ISKCON Bangalore Lectures","label":"From Senior devotees lectures","notebookId":"da406743-a373-47f9-9275-6c2e1e86c2b6"},
  {"key":"Bhaktivedanta NotebookLM","label":"From Srila Prabhupad'\''s books","notebookId":"09d526e1-8762-4a1b-897c-d4cafccafa53"},
  {"key":"Srila Prabhupada Letters & Correspondence","label":"From Srila Prabhupad'\''s letters and correspondence","notebookId":"c93d81ab-2e8a-49ed-b6c2-99248603d8b5"},
  {"key":"Srila Prabhupada Audio Transcripts","label":"From Srila Prabhupad'\''s audio transcripts","notebookId":"9234d4c1-c121-47ae-938f-721aa4c5b907"}
]'

# SUPABASE_URL: Planned server-only Story 1.13 citation-store endpoint.
# Configure a preview-safe Supabase project for Vercel Preview when available.
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: Planned server-only Story 1.13 citation-store key.
# Never expose this in browser code or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# TATTVAM_LECTURE_CITATIONS_TABLE: Optional Story 1.13 override for the lecture citation table name.
TATTVAM_LECTURE_CITATIONS_TABLE="lecture_citations"
